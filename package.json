{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "Complete E-Commerce Backend with Microservices",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx concurrently \"npm:dev:*\" --kill-others-on-fail",
    "dev:gateway": "npx tsx watch src/services/api-gateway/server.ts",
    "dev:products": "npx tsx watch src/services/product-catalog/server.ts",
    "dev:orders": "npx tsx watch src/services/order/server.ts",
    "dev:inventory": "npx tsx watch src/services/inventory/server.ts",
    "dev:notifications": "npx tsx watch src/services/notification/server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:gateway": "node dist/services/api-gateway/server.js",
    "start:products": "node dist/services/product-catalog/server.js",
    "start:orders": "node dist/services/order/server.js",
    "start:inventory": "node dist/services/inventory/server.js",
    "start:notifications": "node dist/services/notification/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "rabbitmq:setup": "bash scripts/setup-rabbitmq.sh",
    "rabbitmq:test": "bash scripts/test-rabbitmq.sh",
    "clean": "rm -rf dist node_modules",
    "redis:commander": "redis-commander --port 8081"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/fastify": "^6.20.3",
    "@fastify/compress": "^7.0.3",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@prisma/client": "^5.11.0",
    "@sentry/node": "^10.42.0",
    "amqplib": "^0.10.9",
    "argon2": "^0.31.2",
    "axios": "^1.6.7",
    "bullmq": "^5.1.9",
    "dotenv": "^17.3.1",
    "fastify": "^4.26.1",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.9",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "socket.io": "^4.6.1",
    "stripe": "^14.17.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.14",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.2",
    "jest": "^30.3.0",
    "prisma": "^5.11.0",
    "redis-commander": "^0.9.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
